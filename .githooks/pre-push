#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

info()    { echo -e "${CYAN}[pre-push]${NC} $*"; }
success() { echo -e "${GREEN}[pre-push]${NC} $*"; }
warn()    { echo -e "${YELLOW}[pre-push]${NC} $*"; }
error()   { echo -e "${RED}[pre-push]${NC} $*" >&2; }

# stdin からプッシュ対象の SHA を読み取る
LOCAL_SHA=""
REMOTE_SHA=""
while read -r local_ref local_sha remote_ref remote_sha; do
  LOCAL_SHA="$local_sha"
  REMOTE_SHA="$remote_sha"
done

ZERO="0000000000000000000000000000000000000000"

# ブランチ削除 push（LOCAL_SHA=ZERO）はスキップ
if [ -z "$LOCAL_SHA" ] || [ "$LOCAL_SHA" = "$ZERO" ]; then
  exit 0
fi

if [ "$REMOTE_SHA" = "$ZERO" ]; then
  # 新規ブランチ：main との差分で変更ファイルを検出
  BASE=$(git merge-base "$LOCAL_SHA" main 2>/dev/null || true)
  if [ -n "$BASE" ]; then
    CHANGED=$(git diff --name-only "$BASE" "$LOCAL_SHA")
  else
    CHANGED=$(git diff-tree --no-commit-id -r --name-only "$LOCAL_SHA")
  fi
else
  CHANGED=$(git diff --name-only "$REMOTE_SHA" "$LOCAL_SHA")
fi

# 変更ファイルを行単位で走査（スペース含むファイル名対応）
BACKEND_CHANGED=false
MOBILE_CHANGED=false
while IFS= read -r f; do
  if [[ "$f" == backend/* || "$f" == api/openapi.yaml || "$f" == .github/workflows/backend-ci.yml ]]; then
    BACKEND_CHANGED=true
  fi
  if [[ "$f" == mobile/* || "$f" == api/openapi.yaml || "$f" == .github/workflows/mobile-ci.yml ]]; then
    MOBILE_CHANGED=true
  fi
done <<< "$CHANGED"

if [ "$BACKEND_CHANGED" = false ] && [ "$MOBILE_CHANGED" = false ]; then
  success "backend/mobile の変更なし。チェックをスキップします。"
  exit 0
fi

# ============================================================
# Backend チェック
# ============================================================
if [ "$BACKEND_CHANGED" = true ]; then
  info "backend の変更を検出。CI チェックを実行します..."
  cd "$(git rev-parse --show-toplevel)/backend"

  # --- ktlint ---
  info "ktlintCheck を実行中..."
  if ! ./gradlew ktlintCheck -q; then
    error "ktlintCheck に失敗しました。./gradlew ktlintFormat で修正できます。"
    exit 1
  fi
  success "ktlintCheck OK"

  # --- Detekt ---
  info "detekt を実行中..."
  if ! ./gradlew detekt -q; then
    error "detekt に失敗しました。レポートを確認してください: build/reports/detekt/"
    exit 1
  fi
  success "detekt OK"

  # --- Test（PostgreSQL が起動中の場合のみ）---
  if nc -z localhost 5432 2>/dev/null; then
    info "PostgreSQL を検出。テストを実行中..."
    if ! ./gradlew test -q \
        -Dspring.datasource.url=jdbc:postgresql://localhost:5432/cleaning_app \
        -Dspring.datasource.username=cleaning \
        -Dspring.datasource.password=cleaning; then
      error "テストに失敗しました。レポートを確認してください: build/reports/tests/"
      exit 1
    fi
    success "テスト OK"
  else
    warn "PostgreSQL が localhost:5432 で見つかりません。テストをスキップします。"
    warn "CI でテストが実行されます。"
  fi
fi

# ============================================================
# Mobile チェック
# ============================================================
if [ "$MOBILE_CHANGED" = true ]; then
  info "mobile の変更を検出。CI チェックを実行します..."
  REPO_ROOT="$(git rev-parse --show-toplevel)"

  # --- TypeScript API クライアント生成 ---
  info "TypeScript API クライアントを生成中..."
  if ! npx --yes @openapitools/openapi-generator-cli generate \
      --input-spec "$REPO_ROOT/api/openapi.yaml" \
      --generator-name typescript-fetch \
      --output "$REPO_ROOT/mobile/src/shared/api" \
      --additional-properties=typescriptThreePlus=true; then
    error "API クライアントの生成に失敗しました。"
    exit 1
  fi
  success "API クライアント生成 OK"

  cd "$REPO_ROOT/mobile"

  # --- ESLint ---
  info "ESLint を実行中..."
  if ! npm run lint; then
    error "ESLint に失敗しました。npx eslint src/ --fix で自動修正できます。"
    exit 1
  fi
  success "ESLint OK"

  # --- TypeScript 型チェック ---
  info "TypeScript 型チェックを実行中..."
  if ! npx tsc --noEmit; then
    error "TypeScript 型チェックに失敗しました。"
    exit 1
  fi
  success "TypeScript OK"

  # --- Jest ---
  info "Jest を実行中..."
  if ! npm test; then
    error "テストに失敗しました。"
    exit 1
  fi
  success "Jest OK"
fi

success "すべてのチェックが通りました。プッシュを続行します。"
