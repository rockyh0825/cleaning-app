#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

info()    { echo -e "${CYAN}[pre-push]${NC} $*"; }
success() { echo -e "${GREEN}[pre-push]${NC} $*"; }
warn()    { echo -e "${YELLOW}[pre-push]${NC} $*"; }
error()   { echo -e "${RED}[pre-push]${NC} $*" >&2; }

# プッシュ対象のリモートSHAを読み取る（stdin から）
LOCAL_SHA=""
REMOTE_SHA=""
while read -r local_ref local_sha remote_ref remote_sha; do
  LOCAL_SHA="$local_sha"
  REMOTE_SHA="$remote_sha"
done

# プッシュ対象がない場合（削除のみ等）はスキップ
if [ -z "$LOCAL_SHA" ]; then
  exit 0
fi

ZERO="0000000000000000000000000000000000000000"
if [ "$REMOTE_SHA" = "$ZERO" ]; then
  # 新規ブランチ：mainとの差分を見る
  BASE=$(git merge-base HEAD main 2>/dev/null || echo "HEAD~1")
  CHANGED=$(git diff --name-only "$BASE" HEAD)
else
  CHANGED=$(git diff --name-only "$REMOTE_SHA" HEAD)
fi

BACKEND_CHANGED=false
for f in $CHANGED; do
  if [[ "$f" == backend/* || "$f" == .github/workflows/backend-ci.yml ]]; then
    BACKEND_CHANGED=true
    break
  fi
done

if [ "$BACKEND_CHANGED" = false ]; then
  success "backend の変更なし。チェックをスキップします。"
  exit 0
fi

info "backend の変更を検出。CI チェックを実行します..."
cd "$(git rev-parse --show-toplevel)/backend"

# --- ktlint ---
info "ktlintCheck を実行中..."
if ! ./gradlew ktlintCheck -q; then
  error "ktlintCheck に失敗しました。./gradlew ktlintFormat で修正できます。"
  exit 1
fi
success "ktlintCheck OK"

# --- Detekt ---
info "detekt を実行中..."
if ! ./gradlew detekt -q; then
  error "detekt に失敗しました。レポートを確認してください: backend/build/reports/detekt/"
  exit 1
fi
success "detekt OK"

# --- Test（PostgreSQL が起動中の場合のみ）---
if nc -z localhost 5432 2>/dev/null; then
  info "PostgreSQL を検出。テストを実行中..."
  if ! ./gradlew test -q \
      -Dspring.datasource.url=jdbc:postgresql://localhost:5432/cleaning_app \
      -Dspring.datasource.username=cleaning \
      -Dspring.datasource.password=cleaning; then
    error "テストに失敗しました。レポートを確認してください: backend/build/reports/tests/"
    exit 1
  fi
  success "テスト OK"
else
  warn "PostgreSQL が localhost:5432 で見つかりません。テストをスキップします。"
  warn "CI でテストが実行されます。"
fi

success "すべてのチェックが通りました。プッシュを続行します。"
